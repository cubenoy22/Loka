{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "macos-debug",
      "displayName": "macOS Debug (Ninja)",
      "generator": "Ninja",
      "binaryDir": "build/macos/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release (Ninja)",
      "generator": "Ninja",
      "binaryDir": "build/macos/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "win32-debug",
      "displayName": "Win32 Debug (Ninja)",
      "generator": "Ninja",
      "binaryDir": "build/win32/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "win32-release",
      "displayName": "Win32 Release (Ninja)",
      "generator": "Ninja",
      "binaryDir": "build/win32/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "win32-xp-debug",
      "displayName": "Win32 XP Debug (Ninja)",
      "generator": "Ninja",
      "binaryDir": "build-xp/Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_FLAGS": "/D_WIN32_WINNT=0x0501 /DWINVER=0x0501",
        "CMAKE_CXX_FLAGS": "/D_WIN32_WINNT=0x0501 /DWINVER=0x0501",
        "CMAKE_EXE_LINKER_FLAGS": "/SUBSYSTEM:WINDOWS,5.01",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDebug"
      }
    },
    {
      "name": "win32-xp-release",
      "displayName": "Win32 XP Release (Ninja)",
      "generator": "Ninja",
      "binaryDir": "build-xp/Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS": "/D_WIN32_WINNT=0x0501 /DWINVER=0x0501",
        "CMAKE_CXX_FLAGS": "/D_WIN32_WINNT=0x0501 /DWINVER=0x0501",
        "CMAKE_EXE_LINKER_FLAGS": "/SUBSYSTEM:WINDOWS,5.01",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug"
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-release"
    },
    {
      "name": "macos-tests",
      "configurePreset": "macos-debug"
    },
    {
      "name": "win32-debug",
      "configurePreset": "win32-debug"
    },
    {
      "name": "win32-release",
      "configurePreset": "win32-release"
    },
    {
      "name": "win32-tests",
      "configurePreset": "win32-debug"
    },
    {
      "name": "win32-xp-debug",
      "configurePreset": "win32-xp-debug",
      "configuration": "Debug"
    },
    {
      "name": "win32-xp-release",
      "configurePreset": "win32-xp-release",
      "configuration": "Release"
    }
  ]
}
