{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run (macOS HelloWorld)",
      "type": "lldb-dap",
      "request": "launch",
      "program": "${workspaceFolder}/build/macos/Debug/example/HelloWorld/LokaHelloMacOS",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build: macOS App"
    },
    {
      "name": "Run (macOS MineSweeper)",
      "type": "lldb-dap",
      "request": "launch",
      "program": "${workspaceFolder}/build/macos/Debug/example/MineSweeper/LokaMineMacOS",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build: macOS MineSweeper"
    },
    {
      "name": "Run (macOS SimpleViewer)",
      "type": "lldb-dap",
      "request": "launch",
      "program": "${workspaceFolder}/build/macos/Debug/example/SimpleViewer/LokaSimpleViewerMacOS",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build: macOS SimpleViewer"
    },
    {
      "name": "Run (macOS FloppyBird)",
      "type": "lldb-dap",
      "request": "launch",
      "program": "${workspaceFolder}/build/macos/Debug/example/FloppyBird/LokaFloppyBirdMacOS",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build: macOS FloppyBird"
    },
    {
      "name": "Run (macOS Tutorial)",
      "type": "lldb-dap",
      "request": "launch",
      "program": "${workspaceFolder}/build/macos/Debug/example/Tutorial/LokaTutorialMacOS",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build: macOS Tutorial"
    },
    {
      "name": "Attach (MAME 68K gdbstub, Tutorial)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/retro68/68k/Release/example/Tutorial/LokaTutorial68K.code.bin.gdb",
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      // WSL-side debugger: use "WSL: Reopen Folder in WSL" for this configuration.
      "miDebuggerPath": "/usr/bin/gdb-multiarch",
      "miDebuggerServerAddress": "localhost:23946",
      "setupCommands": [
        { "text": "set architecture m68k", "ignoreFailures": false },
        { "text": "set endian big", "ignoreFailures": false }
      ],
      "externalConsole": false
    },
    {
      "name": "Run (Windows HelloWorld)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/win32/Debug/example/HelloWorld/LokaHelloWin32.exe",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "preLaunchTask": "Build: Win32 App"
    },
    {
      "name": "Run (Windows MineSweeper)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/win32/Debug/example/MineSweeper/LokaMineWin32.exe",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "preLaunchTask": "Build: Win32 MineSweeper"
    },
    {
      "name": "Run (Windows SimpleViewer)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/win32/Debug/example/SimpleViewer/LokaSimpleViewerWin32.exe",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "preLaunchTask": "Build: Win32 SimpleViewer"
    },
    {
      "name": "Run (Windows FloppyBird)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/win32/Debug/example/FloppyBird/LokaFloppyBirdWin32.exe",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "preLaunchTask": "Build: Win32 FloppyBird"
    },
    {
      "name": "Run (Windows Tutorial)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/win32/Debug/example/Tutorial/LokaTutorialWin32.exe",
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "preLaunchTask": "Build: Win32 Tutorial"
    }
  ]
}
