      "problemMatcher": "$gcc"
    },
    {
      "label": "Build: macOS Tutorial",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "macos-debug",
        "--target",
        "LokaTutorialMacOS"
      ],
