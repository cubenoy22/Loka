    {
      "label": "MAME: Mount .dsk (pick app)",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mame-mount.sh",
      "args": ["${workspaceFolder}/${input:retro68DskPath}"],
      "windows": {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\mame-mount.ps1\""
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "retro68DskPath",
      "type": "pickString",
      "description": "Select Retro68 68K app floppy to mount in MAME",
      "options": [
        {
          "label": "HelloWorld",
          "value": "build/retro68/68k/Release/example/HelloWorld/LokaHello68K.dsk"
        },
        {
          "label": "MineSweeper",
          "value": "build/retro68/68k/Release/example/MineSweeper/LokaMine68K.dsk"
        },
        {
          "label": "SimpleViewer",
          "value": "build/retro68/68k/Release/example/SimpleViewer/LokaSimpleViewer68K.dsk"
        },
        {
          "label": "FloppyBird",
          "value": "build/retro68/68k/Release/example/FloppyBird/LokaFloppyBird68K.dsk"
        },
        {
          "label": "Tutorial",
          "value": "build/retro68/68k/Release/example/Tutorial/LokaTutorial68K.dsk"
        }
      ]
    }
  ]
}
