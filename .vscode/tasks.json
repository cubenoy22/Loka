{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure HelloWorld (Native-Debug-Console)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "example/HelloWorld",
        "-B",
        "example/HelloWorld/build/native",
        "-DUSE_CONSOLE_SUBSYSTEM=ON",
        "-DTEST_BUILD=ON"
      ]
    },
    {
      "label": "Build HelloWorld (Native-Debug-Console)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "example/HelloWorld/build/native",
        "--config",
        "Debug"
      ],
      "dependsOn": [
        "Configure HelloWorld (Native-Debug-Console)"
      ],
      "group": "build"
    },
    {
      "label": "Configure HelloWorld (Native-Debug-GUI)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "example/HelloWorld",
        "-B",
        "example/HelloWorld/build/native",
        "-DUSE_CONSOLE_SUBSYSTEM=OFF"
      ]
    },
    {
      "label": "Build HelloWorld (Native-Debug-GUI)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "example/HelloWorld/build/native",
        "--config",
        "Debug"
      ],
      "dependsOn": [
        "Configure HelloWorld (Native-Debug-GUI)"
      ],
      "group": "build"
    },
    {
      "label": "Config & Build HelloWorld (Native-Debug-GUI)",
      "dependsOn": [
        "Configure HelloWorld (Native-Debug-GUI)",
        "Build HelloWorld (Native-Debug-GUI)"
      ],
      "group": "build"
    },
    {
      "label": "Config & Build HelloWorld (Native-Debug-Console)",
      "dependsOn": [
        "Configure HelloWorld (Native-Debug-Console)",
        "Build HelloWorld (Native-Debug-Console)"
      ],
      "group": "build"
    }
  ]
}