        "--preset",
        "win32-debug",
        "--target",
        "LokaTutorialWin32"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build: Win32 Tests",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "win32-tests",
        "--target",
        "LokaTestsWin32"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
