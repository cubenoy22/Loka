{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure: macOS Native",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "macos-debug"
      ],
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
