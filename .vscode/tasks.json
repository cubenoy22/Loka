      "label": "Prepare SCSI Dev Disk: FloppyBird",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mame-dev-disk.sh",
      "args": ["${workspaceFolder}/build/retro68/68k/Release/example/FloppyBird/LokaFloppyBird68K.bin"],
      "windows": {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\mame-dev-disk.ps1\""
      },
      "problemMatcher": []
    },
    {
      "label": "Prepare SCSI Dev Disk: Tutorial",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mame-dev-disk.sh",
      "args": ["${workspaceFolder}/build/retro68/68k/Release/example/Tutorial/LokaTutorial68K.bin"],
      "windows": {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\mame-dev-disk.ps1\""
      },
      "problemMatcher": []
    },
    {
      "label": "MAME: Start",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mame-run.sh",
      "windows": {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\mame-run.ps1\""
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "MAME: Eject Floppy",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mame-mount.sh",
      "args": ["--eject"],
      "windows": {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\mame-mount.ps1\""
      },
      "problemMatcher": []
    },
    {
      "label": "MAME: Mount HelloWorld",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mame-mount.sh",
      "args": ["${workspaceFolder}/build/retro68/68k/Release/example/HelloWorld/LokaHello68K.dsk"],
      "windows": {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\mame-mount.ps1\""
      },
      "problemMatcher": []
    },
    {
      "label": "MAME: Mount MineSweeper",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mame-mount.sh",
      "args": ["${workspaceFolder}/build/retro68/68k/Release/example/MineSweeper/LokaMine68K.dsk"],
      "windows": {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\mame-mount.ps1\""
      },
      "problemMatcher": []
    },
    {
      "label": "MAME: Mount SimpleViewer",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mame-mount.sh",
      "args": ["${workspaceFolder}/build/retro68/68k/Release/example/SimpleViewer/LokaSimpleViewer68K.dsk"],
      "windows": {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\mame-mount.ps1\""
      },
      "problemMatcher": []
    },
    {
      "label": "MAME: Mount FloppyBird",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mame-mount.sh",
      "args": ["${workspaceFolder}/build/retro68/68k/Release/example/FloppyBird/LokaFloppyBird68K.dsk"],
      "windows": {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\mame-mount.ps1\""
