      "label": "MAME: Mount Tutorial",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mame-mount.sh",
      "args": ["${workspaceFolder}/build/retro68/68k/Release/example/Tutorial/LokaTutorial68K.dsk"],
      "windows": {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\mame-mount.ps1\""
      },
      "problemMatcher": []
    },
    {
      "label": "Build & Mount in MAME: HelloWorld",
      "dependsOn": ["MAME: Eject Floppy", "Build: Retro68 68K HelloWorld", "MAME: Mount HelloWorld"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Build & Mount in MAME: MineSweeper",
      "dependsOn": ["MAME: Eject Floppy", "Build: Retro68 68K MineSweeper", "MAME: Mount MineSweeper"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Build & Mount in MAME: SimpleViewer",
      "dependsOn": ["MAME: Eject Floppy", "Build: Retro68 68K SimpleViewer", "MAME: Mount SimpleViewer"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Build & Mount in MAME: FloppyBird",
      "dependsOn": ["MAME: Eject Floppy", "Build: Retro68 68K FloppyBird", "MAME: Mount FloppyBird"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Build & Mount in MAME: Tutorial",
      "dependsOn": ["MAME: Eject Floppy", "Build: Retro68 68K Tutorial", "MAME: Mount Tutorial"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Build & Start in MAME via SCSI: HelloWorld",
      "dependsOn": ["Build: Retro68 68K HelloWorld", "Prepare SCSI Dev Disk: HelloWorld", "MAME: Start"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Build & Start in MAME via SCSI: MineSweeper",
      "dependsOn": ["Build: Retro68 68K MineSweeper", "Prepare SCSI Dev Disk: MineSweeper", "MAME: Start"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Build & Start in MAME via SCSI: SimpleViewer",
      "dependsOn": ["Build: Retro68 68K SimpleViewer", "Prepare SCSI Dev Disk: SimpleViewer", "MAME: Start"],
