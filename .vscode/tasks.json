{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure (Native-Debug-Console)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "win32",
        "-B",
        "win32/build/native/Debug",
        "-DUSE_CONSOLE_SUBSYSTEM=ON"
      ]
    },
    {
      "label": "Build (Native-Debug-Console)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "win32/build/native/Debug"
      ],
      "dependsOn": [
        "Configure (Native-Debug-Console)"
      ],
      "group": "build"
    },
    {
      "label": "Configure (Native-Debug-GUI)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "win32",
        "-B",
        "win32/build/native/Debug",
        "-DUSE_CONSOLE_SUBSYSTEM=OFF"
      ]
    },
    {
      "label": "Build (Native-Debug-GUI)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "win32/build/native/Debug"
      ],
      "dependsOn": [
        "Configure (Native-Debug-GUI)"
      ],
      "group": "build"
    },
    {
      "label": "Config & Build (Native-Debug-GUI)",
      "dependsOn": [
        "Configure (Native-Debug-GUI)",
        "Build (Native-Debug-GUI)"
      ],
      "group": "build"
    },
    {
      "label": "Config & Build (Native-Debug-Console)",
      "dependsOn": [
        "Configure (Native-Debug-Console)",
        "Build (Native-Debug-Console)"
      ],
      "group": "build"
    }
  ]
}