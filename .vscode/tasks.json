      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Configure HelloWorld (Native-Debug-Console)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "example/HelloWorld",
        "-B",
        "example/HelloWorld/build/native",
        "-DUSE_CONSOLE_SUBSYSTEM=ON",
        "-DTEST_BUILD=ON"
      ]
    },
    {
      "label": "Build HelloWorld (Native-Debug-Console)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "example/HelloWorld/build/native",
        "--config",
        "Debug"
      ],
      "dependsOn": [
        "Configure HelloWorld (Native-Debug-Console)"
      ],
      "group": "build"
    },
    {
      "label": "Configure HelloWorld (Native-Debug-GUI)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "example/HelloWorld",
        "-B",
        "example/HelloWorld/build/native",
        "-DUSE_CONSOLE_SUBSYSTEM=OFF"
      ]
    },
    {
      "label": "Build HelloWorld (Native-Debug-GUI)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "example/HelloWorld/build/native",
        "--config",
        "Debug"
      ],
      "dependsOn": [
        "Configure HelloWorld (Native-Debug-GUI)"
      ],
      "group": "build"
    },
    {
      "label": "Config & Build HelloWorld (Native-Debug-GUI)",
      "dependsOn": [
        "Configure HelloWorld (Native-Debug-GUI)",
        "Build HelloWorld (Native-Debug-GUI)"
      ],
      "group": "build"
    },
    {
      "label": "Config & Build HelloWorld (Native-Debug-Console)",
      "dependsOn": [
        "Configure HelloWorld (Native-Debug-Console)",
        "Build HelloWorld (Native-Debug-Console)"
      ],
      "group": "build"
    },
    {
      "label": "Configure HelloWorld (Native-Release-Console)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "example/HelloWorld",
        "-B",
        "example/HelloWorld/build/native-release",
        "-DUSE_CONSOLE_SUBSYSTEM=ON",
        "-DTEST_BUILD=ON",
        "-DCMAKE_BUILD_TYPE=Release"
      ]
    },
    {
      "label": "Build HelloWorld (Native-Release-Console)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "example/HelloWorld/build/native-release",
        "--config",
        "Release"
      ],
      "dependsOn": [
        "Configure HelloWorld (Native-Release-Console)"
      ],
      "group": "build"
    },
    {
      "label": "Configure HelloWorld (Native-Release-GUI)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "example/HelloWorld",
        "-B",
        "example/HelloWorld/build/native-release",
        "-DUSE_CONSOLE_SUBSYSTEM=OFF",
        "-DCMAKE_BUILD_TYPE=Release"
      ]
    },
    {
      "label": "Build HelloWorld (Native-Release-GUI)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "example/HelloWorld/build/native-release",
        "--config",
        "Release"
      ],
      "dependsOn": [
        "Configure HelloWorld (Native-Release-GUI)"
      ],
      "group": "build"
    },
    {
      "label": "Config & Build HelloWorld (Native-Release-GUI)",
      "dependsOn": [
        "Configure HelloWorld (Native-Release-GUI)",
        "Build HelloWorld (Native-Release-GUI)"
      ],
      "group": "build"
    },
    {
      "label": "Config & Build HelloWorld (Native-Release-Console)",
      "dependsOn": [
        "Configure HelloWorld (Native-Release-Console)",
        "Build HelloWorld (Native-Release-Console)"
      ],
      "group": "build"
    },
    {
      "type": "cmake",
      "label": "CMake: clean rebuild",
      "command": "cleanRebuild",
      "targets": [
        "LokaHelloMacOS"
      ],
      "preset": "macos-debug",
      "group": "build",
      "problemMatcher": [],
      "detail": "CMake template clean rebuild task"
    },
    {
      "label": "Build: Retro68 68K HelloWorld",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "retro68-68k-release",
        "--target",
        "LokaHello68K_APPL"
      ],
      "dependsOn": [
        "Configure: Retro68 68K"
      ],
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Build: Retro68 68K MineSweeper",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "retro68-68k-release",
        "--target",
        "LokaMine68K_APPL"
      ],
      "dependsOn": [
        "Configure: Retro68 68K"
      ],
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Build: Retro68 68K SimpleViewer",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "retro68-68k-release",
        "--target",
        "LokaSimpleViewer68K_APPL"
      ],
      "dependsOn": [
        "Configure: Retro68 68K"
      ],
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Build: Retro68 68K FloppyBird",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "retro68-68k-release",
        "--target",
        "LokaFloppyBird68K_APPL"
      ],
      "dependsOn": [
        "Configure: Retro68 68K"
      ],
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Build: Retro68 68K Tutorial",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "retro68-68k-release",
        "--target",
        "LokaTutorial68K_APPL"
      ],
      "dependsOn": [
        "Configure: Retro68 68K"
      ],
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Prepare SCSI Dev Disk: HelloWorld",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mame-dev-disk.sh",
      "args": ["${workspaceFolder}/build/retro68/68k/Release/example/HelloWorld/LokaHello68K.bin"],
      "windows": {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\mame-dev-disk.ps1\""
      },
      "problemMatcher": []
    },
    {
      "label": "Prepare SCSI Dev Disk: MineSweeper",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mame-dev-disk.sh",
      "args": ["${workspaceFolder}/build/retro68/68k/Release/example/MineSweeper/LokaMine68K.bin"],
      "windows": {
        "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${workspaceFolder}\\scripts\\mame-dev-disk.ps1\""
      },
      "problemMatcher": []
    },
    {
      "label": "Prepare SCSI Dev Disk: SimpleViewer",
      "type": "shell",
